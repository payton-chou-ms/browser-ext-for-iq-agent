# IQ Copilot Proxy — Environment Variables
# Copy this file to .env and fill in your values.
# .env is git-ignored and NEVER committed to source control.

# ── Copilot CLI ──
# CLI_PORT=4321
# HTTP_PORT=8321

# ── Azure Foundry (optional) ──
# Your Azure OpenAI endpoint URL
# FOUNDRY_ENDPOINT=https://your-resource.openai.azure.com/

# Your Azure OpenAI API key — NEVER commit this value
# FOUNDRY_API_KEY=sk-xxxxx
