{
  "manifest_version": 3,
  "name": "IQ Copilot",
  "version": "1.0.0",
  "description": "AI-powered Copilot sidebar — connected to GitHub Copilot SDK",
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_icon": "icons/icon48.png",
    "default_title": "開啟 IQ Copilot"
  },
  "side_panel": {
    "default_path": "sidebar.html"
  },
  "permissions": [
    "activeTab",
    "sidePanel",
    "tabs",
    "storage",
    "alarms"
  ],
  "host_permissions": [
    "http://localhost/*",
    "http://127.0.0.1/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "http://*/*",
        "https://*/*"
      ],
      "run_at": "document_idle",
      "js": [
        "content_script.js"
      ]
    }
  ]
}
